# Pi Monitor history collector
# Collects a small rolling 5-day history for Pi-specific health trends.
#
# Shell section:
# - reads live Pi-specific values from sysfs, vcgencmd, and df
# - detects attached USB storage when present
# - passes a normalized snapshot into the Python retention writer

set -eu

# Storage location and retention window for the rolling history file.
DATA_DIR="/var/lib/pi-monitor"
HISTORY_FILE="$DATA_DIR/history.ndjson"
RETENTION_SECONDS=$((5 * 24 * 60 * 60))

mkdir -p "$DATA_DIR"
[ -f "$HISTORY_FILE" ] || : > "$HISTORY_FILE"

CPU_RAW=""
IO_RAW=""
NVME_RAW=""

for HWMON_DIR in /sys/class/hwmon/hwmon*; do
  [ -r "$HWMON_DIR/name" ] || continue
  NAME=$(cat "$HWMON_DIR/name" 2>/dev/null || true)

  if [ "$NAME" = "cpu_thermal" ]; then
    CPU_RAW=$(cat "$HWMON_DIR/temp1_input" 2>/dev/null || true)
  fi

  if [ "$NAME" = "rp1_adc" ]; then
    IO_RAW=$(cat "$HWMON_DIR/temp1_input" 2>/dev/null || true)
  fi
done

if [ -b /dev/nvme0n1 ]; then
  NVME_RAW=$(
    (
      sudo -n smartctl -a /dev/nvme0n1 2>/dev/null ||
      smartctl -a /dev/nvme0n1 2>/dev/null ||
      true
    ) | awk -F: '
      BEGIN { IGNORECASE=1 }
      /^[[:space:]]*Temperature[[:space:]]*:/ {
        gsub(/^[[:space:]]+|[[:space:]]+$/, "", $2)
        if (match($2, /[-+]?[0-9]+/)) {
          printf "%d", substr($2, RSTART, RLENGTH) * 1000
          exit
        }
      }
    '
  )
fi

PMIC_RAW=$(vcgencmd measure_temp pmic 2>/dev/null | sed "s/.*=//; s/'C//" | awk '{printf "%d", $1 * 1000}' || true)
THROTTLED_RAW=$(vcgencmd get_throttled 2>/dev/null || echo throttled=0x0)
ROOT_USED_PCT=$(df -P / 2>/dev/null | awk 'NR==2 {gsub(/%/, "", $5); print $5}')

ROOT_DEV=$(findmnt -n -o SOURCE / 2>/dev/null || true)
USB_FREE_BYTES=""

# Determine whether root or any attached sdX disk is USB-backed storage.
case "$ROOT_DEV" in
  /dev/sd[a-z][0-9]*)
    USB_ROOT_DISK=$(printf '%s\n' "$ROOT_DEV" | sed -E 's#^/dev/(sd[a-z]+)[0-9]+$#\1#')
    ;;
  /dev/sd[a-z])
    USB_ROOT_DISK=$(printf '%s\n' "$ROOT_DEV" | sed -E 's#^/dev/(sd[a-z]+)$#\1#')
    ;;
  *)
    USB_ROOT_DISK=""
    ;;
esac

is_usb_storage_disk() {
  DISK_NAME="$1"
  DISK_DEVICE_PATH=$(readlink -f "/sys/class/block/$DISK_NAME/device" 2>/dev/null || true)
  printf '%s\n' "$DISK_DEVICE_PATH" | grep -q '/usb'
}

USB_STORAGE_DISK=""
if [ -n "$USB_ROOT_DISK" ] && is_usb_storage_disk "$USB_ROOT_DISK"; then
  USB_STORAGE_DISK="$USB_ROOT_DISK"
else
  for DISK_PATH in /sys/class/block/sd*; do
    [ -e "$DISK_PATH" ] || continue
    DISK_NAME=$(basename "$DISK_PATH")
    if is_usb_storage_disk "$DISK_NAME"; then
      USB_STORAGE_DISK="$DISK_NAME"
      break
    fi
  done
fi

if [ -n "$USB_STORAGE_DISK" ]; then
  USB_MOUNT_LINE=$(lsblk -nrpo NAME,MOUNTPOINT "/dev/$USB_STORAGE_DISK" 2>/dev/null | awk '$2 != "" {print $1 "|" $2; exit}')
  if [ -n "$USB_MOUNT_LINE" ]; then
    USB_STORAGE_MOUNT_POINT=$(printf '%s\n' "$USB_MOUNT_LINE" | cut -d'|' -f2-)
    if [ -n "$USB_STORAGE_MOUNT_POINT" ]; then
      USB_FREE_BYTES=$(df -B1 "$USB_STORAGE_MOUNT_POINT" 2>/dev/null | awk 'NR==2 {print $4}')
    fi
  fi
fi

# Python section:
# - appends the newest sample
# - drops expired records outside the 5-day retention window
# - keeps the NDJSON file compact and valid
python3 - "$HISTORY_FILE" "$RETENTION_SECONDS" "$CPU_RAW" "$NVME_RAW" "$IO_RAW" "$PMIC_RAW" "$THROTTLED_RAW" "$ROOT_USED_PCT" "$USB_FREE_BYTES" <<'PY'
import json
import os
import re
import sys
import time
from tempfile import NamedTemporaryFile

history_file = sys.argv[1]
retention_seconds = int(sys.argv[2])
cpu_raw = sys.argv[3]
nvme_raw = sys.argv[4]
io_raw = sys.argv[5]
pmic_raw = sys.argv[6]
throttled_raw = sys.argv[7]
root_used_pct = sys.argv[8]
usb_free_bytes = sys.argv[9]


# Convert raw shell values into JSON-safe integers or null values.
def parse_temp_millic(raw: str):
    try:
        return int(raw)
    except Exception:
        return None


def parse_int(raw: str):
    try:
        return int(raw)
    except Exception:
        return None


# Decode the Raspberry Pi throttled bitmask so the UI can summarize events later.
match = re.search(r"0x([0-9a-fA-F]+)", throttled_raw or "")
value = int(match.group(1), 16) if match else 0

now = int(time.time())
cutoff = now - retention_seconds

record = {
    "ts": now,
    "cpuTemp": parse_temp_millic(cpu_raw),
    "nvmeTemp": parse_temp_millic(nvme_raw),
    "ioTemp": parse_temp_millic(io_raw),
    "pmicTemp": parse_temp_millic(pmic_raw),
    "currentUndervoltage": 1 if (value & (1 << 0)) else 0,
    "currentFreqCap": 1 if (value & (1 << 1)) else 0,
    "currentThrottled": 1 if (value & (1 << 2)) else 0,
    "currentSoftTempLimit": 1 if (value & (1 << 3)) else 0,
    "rootUsedPct": parse_int(root_used_pct),
    "usbFreeBytes": parse_int(usb_free_bytes),
}

os.makedirs(os.path.dirname(history_file), exist_ok=True)
if not os.path.exists(history_file):
    open(history_file, "a", encoding="utf-8").close()

# Rewrite the file atomically so partially written history data is avoided.
with open(history_file, "r", encoding="utf-8") as src, NamedTemporaryFile("w", delete=False, dir=os.path.dirname(history_file), encoding="utf-8") as dst:
    tmp_name = dst.name
    for line in src:
        line = line.strip()
        if not line:
            continue
        try:
            item = json.loads(line)
        except Exception:
            continue
        ts = item.get("ts")
        if isinstance(ts, (int, float)) and ts >= cutoff:
            dst.write(json.dumps(item, separators=(",", ":")) + "\n")
    dst.write(json.dumps(record, separators=(",", ":")) + "\n")

os.replace(tmp_name, history_file)
PY
